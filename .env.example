PORT=3000
SESSION_SECRET=change-me-to-a-random-string

# Public base URL of the live app (no trailing slash) — used to build referral
# invite links (e.g. https://doneche.shabdly.online/register?ref=...)
APP_BASE_URL=https://doneche.shabdly.online


# Supabase (production datastore — leave blank for local lowdb fallback)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Supabase anon/public key — used client-side for password reset (resetPasswordForEmail)
SUPABASE_ANON_KEY=

# Anthropic (Claude) — used for Magic Upload screenshot parsing & inbound email parsing
ANTHROPIC_API_KEY=


# Google AdSense (ONLY ONE verification method used — meta tag in views/partials/head.ejs)
ADSENSE_CLIENT_ID=

# Email notifications (Nodemailer via Gmail) — used to alert on new feedback submissions
EMAIL_USER=
EMAIL_APP_PASSWORD=


