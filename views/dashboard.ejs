<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
  <%- include('partials/nav', { user, activePage: 'dashboard' }) %>


  <main class="dashboard">
    <div class="dashboard-header">
      <h2>Hi, <%= user.name %> 👋 <span class="ghostbuster-tier"><%= gamification.tier.badge %> <%= gamification.tier.title %></span></h2>
      <p>You applied. They went quiet. <strong><%= appsCount %></strong> application<%= appsCount === 1 ? '' : 's' %> tracked <% if (user.plan === 'free') { %>(<%= freeLimit %> slot limit)<% } %></p>
    </div>

    <% if (atLimit) { %>
      <div class="alert">You've hit your limit of <%= freeLimit %> applications. <a href="/pricing">Upgrade</a> or invite friends below to unlock more slots.</div>
    <% } %>

    <!-- "Capacity Expansion" (Dropbox Model): application slot counter -->
    <% if (user.plan === 'free') { %>
      <div class="capacity-widget">
        <div class="capacity-widget-header">
          <span>📦 Storage: <strong><%= appsCount %>/<%= gamification.capacity %></strong> applications</span>
          <button type="button" class="invite-btn" onclick="openReferralModal()">➕ Invite a Colleague for +5 Slots</button>
        </div>
        <div class="capacity-bar">
          <div class="capacity-bar-fill" style="width: <%= Math.min(100, Math.round((appsCount / gamification.capacity) * 100)) %>%"></div>
        </div>
      </div>
    <% } %>

    <!-- "Milestone Unlock" (Feature Wall): AI Interviewer + Resume Matcher -->
    <div class="beta-perk<%= gamification.aiSimulatorUnlocked ? '' : ' locked' %>">
      <div class="beta-perk-badge">
        <% if (gamification.aiSimulatorUnlocked) { %>
          🎁 Premium Beta Perk Unlocked
        <% } else { %>
          🔒 Locked — Invite 1 friend to unlock
        <% } %>
      </div>
      <p class="beta-perk-desc">Practice your interview pitch directly with our AI Simulator.</p>
      <% if (gamification.aiSimulatorUnlocked) { %>
        <button type="button" class="beta-perk-btn" onclick="window.open('https://aistudio.instagram.com/ai/4265674450327484/?utm_source=share', '_blank')">
          🚀 Launch AI Interviewer
        </button>
      <% } else { %>
        <button type="button" class="beta-perk-btn locked-btn" onclick="openReferralModal()">🔒 Unlock with 1 Referral</button>
      <% } %>
    </div>

    <div class="beta-perk<%= gamification.resumeMatcherUnlocked ? '' : ' locked' %>">
      <div class="beta-perk-badge">
        <% if (gamification.resumeMatcherUnlocked) { %>
          🎁 VIP Front-of-Line Access Unlocked
        <% } else { %>
          🔒 Locked — Invite 3 friends to unlock
        <% } %>
      </div>
      <p class="beta-perk-desc">Get VIP front-of-line access to the upcoming AI Resume Matcher.</p>
      <% if (gamification.resumeMatcherUnlocked) { %>
        <a href="/ats-matcher" class="beta-perk-btn">🎯 Try AI Resume Matcher</a>
      <% } else { %>
        <button type="button" class="beta-perk-btn locked-btn" onclick="openReferralModal()">🔒 <%= gamification.referralsToNextUnlock %> more referral<%= gamification.referralsToNextUnlock === 1 ? '' : 's' %> needed</button>
      <% } %>
    </div>



    <form method="POST" action="/applications" class="add-form" id="addAppForm">

      <input type="text" name="company" id="companyInput" placeholder="Company" required />
      <input type="text" name="role" id="roleInput" placeholder="Role" required />
      <input type="date" name="appliedDate" id="appliedDateInput" required />
      <input type="text" name="location" id="locationInput" placeholder="Location (optional)" />
      <input type="text" name="ctcLpa" id="ctcLpaInput" placeholder="CTC (LPA, optional)" />
      <select name="jobType" id="jobTypeInput">
        <option value="">Job Type (optional)</option>
        <option value="WFO">WFO</option>
        <option value="Remote">Remote</option>
        <option value="Hybrid">Hybrid</option>
      </select>
      <input type="text" name="hrContact" id="hrContactInput" placeholder="HR Contact Name (optional)" />
      <input type="email" name="hrEmail" id="hrEmailInput" placeholder="HR Email (optional)" />


      <div class="upload-dropdown" id="uploadDropdown">
        <button type="button" id="uploadScreenshotBtn" onclick="toggleUploadMenu(event)">📎 Magic Upload ▾</button>
        <span class="info-icon" tabindex="0" onclick="event.stopPropagation(); toggleInfoTip()" title="How to upload">ℹ️
          <div class="info-tip" id="uploadInfoTip">
            <strong>Screenshot:</strong> Take a screenshot of your application confirmation (email/portal) and upload it directly.<br/><br/>
            <strong>PDF (Sent Email):</strong> Open the confirmation email you sent to the HR/company, choose "Print &rarr; Save as PDF" (or download it if received), then upload that PDF file here. We'll auto-extract the Company &amp; Role for you to review.
          </div>
        </span>
        <div class="upload-menu" id="uploadMenu">
          <button type="button" onclick="document.getElementById('screenshotFileInput').click()">🖼️ Upload Screenshot</button>
          <button type="button" onclick="document.getElementById('pdfFileInput').click()">📄 Upload PDF (Sent Email)</button>
        </div>
      </div>
      <input type="file" id="screenshotFileInput" accept="image/*" style="display:none" onchange="handleScreenshotUpload(event)" />
      <input type="file" id="pdfFileInput" accept="application/pdf" style="display:none" onchange="handlePdfUpload(event)" />
      <span id="screenshotStatus" class="screenshot-status"></span>


      <button type="submit" id="addAppBtn">+ Add Application</button>
    </form>



    <div class="board">
      <% ['Applied','Interviewing','Ghosted','Rejected','Offered'].forEach(function(col) { %>
        <div class="column column-<%= col.toLowerCase() %>" <%= col === 'Ghosted' ? 'id="ghostedColumn"' : '' %>>

          <h3><%= col %> (<%= columns[col].length %>)</h3>
          <% columns[col].forEach(function(a) { %>
            <div class="card<%= col === 'Ghosted' ? ' ghosted-column-card' : '' %>" data-id="<%= a.id %>" onclick="openCardModal(event, '<%= a.id %>')">
              <div class="card-title"><%= a.role %></div>
              <div class="card-sub"><%= a.company %></div>
              <div class="card-date">Applied: <%= new Date(a.appliedDate).toLocaleDateString() %></div>
              <% if (a.location) { %><div class="card-meta">📍 <%= a.location %></div><% } %>
              <% if (a.ctcLpa) { %><div class="card-meta">💰 <%= a.ctcLpa %> LPA</div><% } %>
              <% if (a.jobType) { %><div class="card-meta">🏢 <%= a.jobType %></div><% } %>
              <% if (col === 'Ghosted') { %>
                <a class="followup-link" href="/applications/<%= a.id %>/followup" onclick="event.stopPropagation()">📋 Copy follow-up email</a>
                <% if (a.hrEmail) { %>
                  <button type="button" class="send-email-btn"
                    data-role="<%= a.role %>"
                    data-company="<%= a.company %>"
                    data-hr-email="<%= a.hrEmail %>"
                    data-hr-contact="<%= a.hrContact || '' %>"
                    data-applied-date="<%= a.appliedDate %>"
                    onclick="event.stopPropagation(); sendFollowUpEmail(this)">✉️ Send Email Now</button>
                <% } %>
              <% } %>

              <form method="POST" action="/applications/<%= a.id %>/status" class="status-select" onclick="event.stopPropagation()">
                <select name="status" onchange="this.form.submit()">
                  <% ['Applied','Interviewing','Ghosted','Rejected','Offered'].forEach(function(s) { %>
                    <option value="<%= s %>" <%= s === col ? 'selected' : '' %>><%= s %></option>
                  <% }) %>
                </select>
              </form>
              <form method="POST" action="/applications/<%= a.id %>/delete" onclick="event.stopPropagation()">
                <button type="submit" class="delete-btn">Delete</button>
              </form>
            </div>
          <% }) %>
        </div>
      <% }) %>
    </div>

    <!-- Coming Soon carousel -->
    <div class="coming-soon">
      <h3>🔮 Coming Soon</h3>
      <div class="carousel">
        <input type="radio" name="carousel-slide" id="slide1" checked>
        <input type="radio" name="carousel-slide" id="slide2">
        <div class="carousel-track">
          <div class="carousel-slide">
            <div class="carousel-card">
              <div class="carousel-icon">🔗</div>
              <h4>LinkedIn Insider Match</h4>
              <p>Instantly identify key connections at your applied companies.</p>
            </div>
          </div>
          <div class="carousel-slide">
            <div class="carousel-card">
              <div class="carousel-icon">🎯</div>
              <h4>ATS Keyword Matcher</h4>
              <p>Scan your resume against the JD to beat the HR bots.</p>
            </div>
          </div>
        </div>
        <div class="carousel-dots">
          <label for="slide1"></label>
          <label for="slide2"></label>
        </div>
      </div>
    </div>
  </main>

  <!-- Share App / Referral floating button (always visible, regardless of plan) -->
  <button type="button" id="shareAppFab" class="share-app-fab" onclick="openReferralModal()">🔗 Share App</button>

  <!-- Feedback / Bug report floating button -->
  <button type="button" id="feedbackFab" class="feedback-fab" onclick="openFeedbackModal()">💬 Feedback</button>


  <!-- Referral / Invite modal ("Milestone Unlock" + "Capacity Expansion" CTA) -->
  <div id="referralModal" class="modal-overlay" onclick="closeReferralModalOnOverlay(event)">
    <div class="modal-box">
      <button class="modal-close" onclick="closeReferralModal()">&times;</button>
      <h3>🚀 Level Up by Inviting Friends</h3>
      <p>Save a friend from the ATS Black Hole — and unlock rewards for yourself.</p>
      <ul class="referral-benefits">
        <li><%= gamification.aiSimulatorUnlocked ? '✅' : '🔒' %> 1 referral — Unlock AI Interview Simulator</li>
        <li><%= gamification.resumeMatcherUnlocked ? '✅' : '🔒' %> 3 referrals — VIP AI Resume Matcher access</li>
        <li><%= gamification.referralCount >= 5 ? '✅' : '🔒' %> 5 referrals — Earn the "Ghostbuster" badge</li>
      </ul>
      <p>Each referral also gives you <strong>+5 application slots</strong>.</p>
      <p>You currently have <strong><%= gamification.referralCount %></strong> referral<%= gamification.referralCount === 1 ? '' : 's' %>.</p>
      <label>Your unique invite link:</label>
      <div class="referral-link-row">
        <input type="text" id="referralLinkInput" readonly value="<%= gamification.referralLink %>" />
        <button type="button" onclick="copyReferralLink()">📋 Copy My Invite Link</button>
      </div>
      <p id="referralCopyFeedback" class="reset-feedback"></p>
    </div>
  </div>

  <!-- Ghostbuster referral toast (social/visual reward) -->
  <% if (typeof referralToastName !== 'undefined' && referralToastName) { %>
    <div id="referralToast" class="referral-toast">
      🎉 Boom! <strong><%= referralToastName %></strong> just joined doneche using your link.
      <% if (gamification.referralCount >= 5) { %> You are officially a <strong>Ghostbuster</strong>! 🏆<% } %>
    </div>
  <% } %>



  <div id="feedbackModal" class="modal-overlay" onclick="closeFeedbackModalOnOverlay(event)">
    <div class="modal-box">
      <button class="modal-close" onclick="closeFeedbackModal()">&times;</button>
      <h3>Report Bug / Feedback</h3>
      <form method="POST" action="/feedback">
        <label>Feedback Type</label>
        <select name="feedbackType" required>
          <option value="Bug">Bug</option>
          <option value="Feature Request">Feature Request</option>
          <option value="General">General</option>
        </select>

        <label>Message</label>
        <textarea name="message" rows="5" placeholder="Tell us what's up..." required></textarea>

        <button type="submit">Submit</button>
      </form>
    </div>
  </div>

  <!-- Card detail modal -->

  <div id="cardModal" class="modal-overlay" onclick="closeCardModalOnOverlay(event)">
    <div class="modal-box">
      <button class="modal-close" onclick="closeCardModal()">&times;</button>
      <h3 id="modalTitle">Application details</h3>
      <form id="modalForm" method="POST">
        <label>Location</label>
        <input type="text" name="location" id="modalLocation" placeholder="e.g., Pune, Nagpur" />

        <label>CTC (LPA)</label>
        <input type="text" name="ctcLpa" id="modalCtc" placeholder="e.g., 12-15" />

        <label>Job Type</label>
        <select name="jobType" id="modalJobType">
          <option value="">Select</option>
          <option value="WFO">WFO</option>
          <option value="Remote">Remote</option>
          <option value="Hybrid">Hybrid</option>
        </select>

        <label>HR Contact Name</label>
        <input type="text" name="hrContact" id="modalHrContact" placeholder="e.g., Pavithra" />

        <label>HR Email</label>
        <input type="email" name="hrEmail" id="modalHrEmail" placeholder="e.g., hr@company.com" />

        <label>Notes / Remarks</label>

        <textarea name="notes" id="modalNotes" rows="4" placeholder="Any remarks..."></textarea>

        <button type="submit">Save details</button>
      </form>
    </div>
  </div>

  <script>
    async function openCardModal(evt, id) {
      if (evt.target.closest('form') || evt.target.tagName === 'A' || evt.target.tagName === 'BUTTON' || evt.target.tagName === 'SELECT') {
        return; // don't open modal when interacting with inner controls
      }
      let app;
      try {
        const res = await fetch('/applications/' + id);
        const contentType = res.headers.get('content-type') || '';
        if (!res.ok || !contentType.includes('application/json')) {
          throw new Error('Could not load application details.');
        }
        app = await res.json();
      } catch (err) {
        if (window.showToast) window.showToast(err.message || 'Failed to load application details.', 'error');
        return;
      }

      document.getElementById('modalTitle').textContent = app.role + ' @ ' + app.company;
      document.getElementById('modalLocation').value = app.location || '';
      document.getElementById('modalCtc').value = app.ctcLpa || '';
      document.getElementById('modalJobType').value = app.jobType || '';
      document.getElementById('modalHrContact').value = app.hrContact || '';
      document.getElementById('modalHrEmail').value = app.hrEmail || '';
      document.getElementById('modalNotes').value = app.notes || '';

      document.getElementById('modalForm').action = '/applications/' + id + '/details';
      document.getElementById('cardModal').classList.add('open');
    }
    function closeCardModal() {
      document.getElementById('cardModal').classList.remove('open');
    }
    function closeCardModalOnOverlay(evt) {
      if (evt.target.id === 'cardModal') closeCardModal();
    }
    function openFeedbackModal() {
      document.getElementById('feedbackModal').classList.add('open');
    }
    function closeFeedbackModal() {
      document.getElementById('feedbackModal').classList.remove('open');
    }
    function closeFeedbackModalOnOverlay(evt) {
      if (evt.target.id === 'feedbackModal') closeFeedbackModal();
    }

    // ---------- Referral modal ----------
    function openReferralModal() {
      document.getElementById('referralModal').classList.add('open');
    }
    function closeReferralModal() {
      document.getElementById('referralModal').classList.remove('open');
    }
    function closeReferralModalOnOverlay(evt) {
      if (evt.target.id === 'referralModal') closeReferralModal();
    }
    function copyReferralLink() {
      const input = document.getElementById('referralLinkInput');
      input.select();
      input.setSelectionRange(0, 99999);
      navigator.clipboard.writeText(input.value).then(function () {
        const fb = document.getElementById('referralCopyFeedback');
        fb.textContent = '✅ Link copied! Go paste it in your WhatsApp/Telegram groups.';
        fb.style.color = '#2ecc71';
        if (window.showToast) window.showToast('Invite link copied to clipboard!', 'success');
      }).catch(function () {
        try {
          document.execCommand('copy');
          if (window.showToast) window.showToast('Invite link copied to clipboard!', 'success');
        } catch (err) {
          if (window.showToast) window.showToast('Could not copy link. Please copy it manually.', 'error');
        }
      });
    }


    // ---------- Ghostbuster toast + confetti (social/visual reward) ----------
    document.addEventListener('DOMContentLoaded', function () {
      const toast = document.getElementById('referralToast');
      if (!toast) return;
      toast.classList.add('show');

      // Lightweight confetti burst using canvas-confetti (loaded via CDN below)
      if (typeof confetti === 'function') {
        confetti({ particleCount: 120, spread: 90, origin: { y: 0.6 } });
      }

      setTimeout(function () {
        toast.classList.remove('show');
      }, 6000);
    });
  </script>

  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.2/dist/confetti.browser.min.js"></script>
  <script>


    // ---------- Magic Upload: apply all extracted fields (mandatory + optional) to the form ----------
    function applyMagicUploadFields(data) {
      if (!data) return;
      if (data.company) document.getElementById('companyInput').value = data.company;
      if (data.role) document.getElementById('roleInput').value = data.role;
      if (data.appliedDate) document.getElementById('appliedDateInput').value = data.appliedDate;
      if (data.location) document.getElementById('locationInput').value = data.location;
      if (data.ctcLpa) document.getElementById('ctcLpaInput').value = data.ctcLpa;
      if (data.jobType) document.getElementById('jobTypeInput').value = data.jobType;
      if (data.hrContact) document.getElementById('hrContactInput').value = data.hrContact;
      if (data.hrEmail) document.getElementById('hrEmailInput').value = data.hrEmail;
    }

    // ---------- Magic Upload: dropdown menu + info tooltip ----------

    function toggleUploadMenu(evt) {
      evt.stopPropagation();
      document.getElementById('uploadMenu').classList.toggle('open');
      document.getElementById('uploadInfoTip').classList.remove('open');
    }
    function toggleInfoTip() {
      document.getElementById('uploadInfoTip').classList.toggle('open');
      document.getElementById('uploadMenu').classList.remove('open');
    }
    document.addEventListener('click', function (evt) {
      if (!evt.target.closest('#uploadDropdown')) {
        document.getElementById('uploadMenu').classList.remove('open');
        document.getElementById('uploadInfoTip').classList.remove('open');
      }
    });

    // Helper: safely parse a fetch Response as JSON. If the server returns
    // an HTML error page (e.g. a 500 stack trace or platform error page)
    // instead of JSON, surface a clean error message instead of the raw
    // "Unexpected token '<' ... is not valid JSON" parser error.
    async function parseJsonResponse(res) {
      const contentType = res.headers.get('content-type') || '';
      if (!contentType.includes('application/json')) {
        const text = await res.text().catch(function () { return ''; });
        throw new Error(
          res.ok
            ? 'Unexpected server response. Please try again.'
            : 'Server error (' + res.status + '). Please try again in a moment.'
        );
      }
      return res.json();
    }

    // ---------- Magic Upload: PDF Parsing (sent email) ----------
    function handlePdfUpload(evt) {
      const file = evt.target.files && evt.target.files[0];
      if (!file) return;
      document.getElementById('uploadMenu').classList.remove('open');
      const statusEl = document.getElementById('screenshotStatus');
      statusEl.textContent = 'Analyzing PDF...';
      statusEl.style.color = '#888';
      const uploadBtn = document.getElementById('uploadScreenshotBtn');
      const restoreBtn = window.setButtonLoading ? window.setButtonLoading(uploadBtn, 'Analyzing...') : function () {};

      const reader = new FileReader();
      reader.onload = async function () {
        try {
          const base64Pdf = reader.result; // data URL
          const res = await fetch('/api/parse-pdf', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ pdf: base64Pdf })
          });
          const data = await parseJsonResponse(res);
          if (!res.ok) throw new Error(data.error || 'Failed to parse PDF.');

          applyMagicUploadFields(data);

          statusEl.textContent = '✅ Auto-filled from PDF! Please review before saving.';
          statusEl.style.color = '#2ecc71';
          if (window.showToast) window.showToast('PDF parsed successfully! Review the auto-filled fields.', 'success');
        } catch (err) {
          const message = err.message || 'Could not parse PDF.';
          statusEl.textContent = '❌ ' + message;
          statusEl.style.color = '#c0392b';
          if (window.showToast) window.showToast(message, 'error');
        } finally {
          evt.target.value = '';
          restoreBtn();
        }
      };
      reader.onerror = function () {
        const message = 'Could not read the selected PDF file.';
        statusEl.textContent = '❌ ' + message;
        statusEl.style.color = '#c0392b';
        if (window.showToast) window.showToast(message, 'error');
        restoreBtn();
      };
      reader.readAsDataURL(file);
    }

    // ---------- Magic Upload: Screenshot Parsing ----------
    function handleScreenshotUpload(evt) {
      document.getElementById('uploadMenu').classList.remove('open');

      const file = evt.target.files && evt.target.files[0];
      if (!file) return;
      const statusEl = document.getElementById('screenshotStatus');
      statusEl.textContent = 'Analyzing screenshot...';
      statusEl.style.color = '#888';
      const uploadBtn = document.getElementById('uploadScreenshotBtn');
      const restoreBtn = window.setButtonLoading ? window.setButtonLoading(uploadBtn, 'Analyzing...') : function () {};

      const reader = new FileReader();
      reader.onload = async function () {
        try {
          const base64Image = reader.result; // data URL
          const res = await fetch('/api/parse-screenshot', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ image: base64Image, mediaType: file.type })
          });
          const data = await parseJsonResponse(res);
          if (!res.ok) throw new Error(data.error || 'Failed to parse screenshot.');

          applyMagicUploadFields(data);

          statusEl.textContent = '✅ Auto-filled! Please review before saving.';
          statusEl.style.color = '#2ecc71';
          if (window.showToast) window.showToast('Screenshot parsed successfully! Review the auto-filled fields.', 'success');
        } catch (err) {
          const message = err.message || 'Could not parse screenshot.';
          statusEl.textContent = '❌ ' + message;
          statusEl.style.color = '#c0392b';
          if (window.showToast) window.showToast(message, 'error');
        } finally {
          evt.target.value = '';
          restoreBtn();
        }
      };
      reader.onerror = function () {
        const message = 'Could not read the selected image file.';
        statusEl.textContent = '❌ ' + message;
        statusEl.style.color = '#c0392b';
        if (window.showToast) window.showToast(message, 'error');
        restoreBtn();
      };
      reader.readAsDataURL(file);
    }


    // ---------- 1-Click Follow-Up Email (mailto:) ----------

    function sendFollowUpEmail(btn) {
      const role = btn.dataset.role;
      const company = btn.dataset.company;
      const hrEmail = btn.dataset.hrEmail;
      const hrContact = btn.dataset.hrContact;
      const appliedDate = btn.dataset.appliedDate ? new Date(btn.dataset.appliedDate).toLocaleDateString() : '';

      const subject = `Following up on my application for ${role} at ${company}`;
      const greeting = hrContact ? `Hi ${hrContact.split(' ')[0]},` : 'Hi there,';
      const body = `${greeting}\n\nI hope you're doing well. I wanted to follow up on my application for the ${role} position at ${company}, submitted on ${appliedDate}. I remain very interested in the opportunity and would love to hear about next steps whenever convenient.\n\nPlease let me know if there's any additional information I can provide.\n\nBest regards,\n[Your Name]`;

      const mailtoLink = `mailto:${encodeURIComponent(hrEmail)}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`;
      window.location.href = mailtoLink;
    }

    // ---------- Loading states on standard form submits (Add/Delete/Status/Feedback/Details) ----------
    document.addEventListener('DOMContentLoaded', function () {
      document.querySelectorAll('form').forEach(function (form) {
        form.addEventListener('submit', function () {
          const btn = form.querySelector('button[type="submit"]');
          if (btn && window.setButtonLoading) {
            window.setButtonLoading(btn, 'Please wait...');
          }
        });
      });
    });

    // ---------- First-Time App Tour (driver.js) ----------

    document.addEventListener('DOMContentLoaded', function () {
      if (localStorage.getItem('tour_completed')) return;
      if (typeof driver === 'undefined') return;

      const driverObj = driver.js.driver({
        showProgress: true,
        onDestroyStarted: () => {
          localStorage.setItem('tour_completed', '1');
          driverObj.destroy();
        },
        steps: [
          {
            element: '#addAppBtn',
            popover: {
              title: '📝 Add your applications',
              description: 'Start by logging every job application you send out here.',
              side: 'bottom'
            }
          },
          {
            element: '#ghostedColumn',
            popover: {
              title: '👻 The Ghosted column',
              description: 'If a company goes silent for 7+ days after Applied or Interviewing, we auto-flag the card here so you never lose track.',
              side: 'left'
            }
          },
          {
            element: '#feedbackFab',
            popover: {
              title: '💬 We want your feedback',
              description: 'Found a bug or have an idea? Tell us here — we read every single one.',
