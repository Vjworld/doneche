<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
  <nav class="topnav">
    <div class="brand">👻 GhostTracker AI</div>
    <div class="nav-links">
      <a href="/dashboard">Board</a>
      <a href="/ats-matcher">ATS Matcher</a>
      <a href="/pricing">Pricing</a>
    </div>
  </nav>
  <main class="simple-page">
    <h2>ATS Keyword Matcher <span class="badge">PRO</span></h2>
    <% if (user.plan !== 'paid') { %>
      <div class="alert">This is a Pro feature. <a href="/pricing">Upgrade for ₹399/mo</a> to unlock unlimited ATS matches.</div>
    <% } %>
    <form method="POST" action="/ats-matcher">
      <label>Job Description</label>
      <textarea name="jobDescription" rows="6" required></textarea>
      <label>Your Resume Text</label>
      <textarea name="resume" rows="6" required></textarea>
      <button type="submit">Find Keyword Gaps</button>
    </form>
    <% if (result) { %>
      <h3>Top missing keywords:</h3>
      <ul>
        <% result.forEach(function(w) { %><li><%= w %></li><% }) %>
      </ul>
    <% } %>
  </main>
</body>
</html>
