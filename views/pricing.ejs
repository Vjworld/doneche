<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head') %></head>
<body>
  <%- include('partials/nav', { user, activePage: 'pricing' }) %>
  <main class="simple-page">
    <a href="/dashboard" class="breadcrumb-back">&larr; Back to Board</a>
    <h2>Pricing</h2>

    <% if (upgrade) { %>
      <div class="alert">Upgrade to Pro to unlock that feature.</div>
    <% } %>
    <div class="pricing-cards">
      <div class="price-card">
        <h3>Free</h3>
        <p class="price">₹0</p>
        <ul>
          <li>Track up to 10 applications</li>
          <li>Kanban board</li>
          <li>Ghost Alert (auto-flag after 7 days)</li>
          <li>Follow-up email templates</li>
          <li>Password reset &amp; secure sign-up <span class="new-tag">NEW</span></li>
          <li>Magic Upload: Screenshot parsing <span class="new-tag">NEW</span></li>
          <li>Magic Upload: PDF (sent email) parsing <span class="new-tag">NEW</span></li>
          <li>Inbound email auto-tracking (forward to add) <span class="new-tag">NEW</span></li>
        </ul>
      </div>
      <div class="price-card featured">
        <h3>Pro</h3>
        <p class="price">₹399/mo</p>
        <ul>
          <li>Unlimited applications</li>
          <li>ATS Keyword Matcher</li>
          <li>Everything in Free</li>
        </ul>

        <% if (user.plan === 'paid') { %>
          <button disabled>Current Plan</button>
        <% } else { %>
          <form method="POST" action="/upgrade">
            <button type="submit">Upgrade Now</button>
          </form>
        <% } %>
      </div>
    </div>
  </main>
</body>
</html>
